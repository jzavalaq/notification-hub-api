# Notification Hub API Environment Variables
# Copy this file to .env and update values for your environment

# Server Configuration
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=prod

# Database Configuration
POSTGRES_DB=notificationhub
POSTGRES_USER=notificationhub
POSTGRES_PASSWORD=your-secure-password-here
DB_URL=jdbc:postgresql://localhost:5432/notificationhub

# HikariCP Connection Pool
HIKARI_MAX_POOL_SIZE=10
HIKARI_MIN_IDLE=2
HIKARI_CONNECTION_TIMEOUT=30000

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Configuration
# Generate a secure secret: openssl rand -base64 64
JWT_SECRET=change-me-in-production-min-256-bits

# Encryption Configuration
# Generate a secure secret: openssl rand -base64 32
ENCRYPTION_SECRET=change-me-in-production-use-256-bit-key

# CORS Configuration
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,https://example.com

# H2 Console (only for development)
H2_CONSOLE_ENABLED=false

# Rate Limiting Configuration
RATE_LIMIT_ENABLED=true
RATE_LIMIT_CAPACITY=100
RATE_LIMIT_REFILL_TOKENS=100
RATE_LIMIT_REFILL_MINUTES=1

# Email Configuration (optional)
# SPRING_MAIL_HOST=smtp.example.com
# SPRING_MAIL_PORT=587
# SPRING_MAIL_USERNAME=your-email@example.com
# SPRING_MAIL_PASSWORD=your-email-password
